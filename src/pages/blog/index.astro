---
import "../../style/global.css";
import BlogPostPreview from "../../components/BlogPostPreview.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { parseISO, format } from "date-fns";
import { getSlugFromPath } from "../../utils/get-slug-from-path";

const siteTitle = "blog";
const description = "Thought dumps and nerdy stuff";

const allPosts = await Astro.glob("../../content/posts/*.md");
const sortedPosts = allPosts
  .sort(
    (a, b) =>
      new Date(b.frontmatter.date).valueOf() -
      new Date(a.frontmatter.date).valueOf(),
  )
  .filter((p) => p.frontmatter.hidden !== true);
---

<BaseLayout title={siteTitle} description={description} win95Title="Blog - Explorer">
  <!-- Dark theme view -->
  <div class="dark-view">
    <div class="mx-auto w-full max-w-4xl px-6 py-16">
      <header class="mb-16 opacity-0 animate-fade-in-up" style="animation-delay: 0s;">
        <h1 class="text-2xl tracking-tight text-text">blog</h1>
        <p class="mt-2 text-sm text-muted">
          thoughts on tech and content. usually goes to twitter, sometimes here.
        </p>
      </header>

      <div class="flex flex-col gap-1">
        {
          sortedPosts.map((p, i) => (
            <div
              class="opacity-0 animate-fade-in-up"
              style={`animation-delay: ${(i + 1) * 0.05}s;`}
            >
              <BlogPostPreview post={p} />
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Win95 theme view -->
  <div class="win95-view relative flex min-h-screen flex-col items-center justify-center p-8 pb-12">
    <div class="win95-window w-full max-w-md">
      <!-- Title bar -->
      <div class="win95-titlebar">
        <span class="win95-titlebar-text">Blog - Explorer</span>
        <div class="win95-titlebar-buttons">
          <button class="win95-titlebar-btn" aria-label="Minimize">_</button>
          <button class="win95-titlebar-btn" aria-label="Maximize">□</button>
          <button class="win95-titlebar-btn" aria-label="Close">×</button>
        </div>
      </div>

      <!-- Menu bar -->
      <div class="win95-menubar">
        <span class="win95-menu-item"><u>F</u>ile</span>
        <span class="win95-menu-item"><u>E</u>dit</span>
        <span class="win95-menu-item"><u>V</u>iew</span>
        <span class="win95-menu-item"><u>H</u>elp</span>
      </div>

      <!-- Address bar -->
      <div class="win95-toolbar">
        <span style="font-size: 11px; margin-right: 4px;">Address:</span>
        <div class="win95-inset" style="flex: 1; padding: 2px 4px;">
          <span style="font-size: 11px;">C:\theo\blog</span>
        </div>
      </div>

      <!-- Window content -->
      <div class="win95-content" style="padding: 4px;">
        <!-- Header section -->
        <div class="mb-2 pb-2" style="border-bottom: 1px solid #808080;">
          <h1 style="font-size: 14px; font-weight: bold; margin-bottom: 2px;">blog</h1>
          <p style="font-size: 11px; color: #808080;">thoughts on tech and content</p>
        </div>

        <!-- Blog posts list -->
        <div class="win95-inset" style="min-height: 200px; max-height: 280px; overflow-y: auto; padding: 2px;">
          <nav class="flex flex-col">
            {
              sortedPosts.map((post) => {
                const url = "/blog/post/" + getSlugFromPath(post.file);
                const date = parseISO(post.frontmatter.date);
                const formattedDate = format(date, "MM/dd/yy");
                return (
                  <a
                    href={url}
                    class="win95-list-item flex items-center gap-2 px-1 py-0.5"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink: 0;">
                      <rect x="2" y="1" width="12" height="14" fill="#ffffff" stroke="#000000" stroke-width="0.5"/>
                      <line x1="4" y1="4" x2="12" y2="4" stroke="#808080" stroke-width="1"/>
                      <line x1="4" y1="6" x2="10" y2="6" stroke="#808080" stroke-width="1"/>
                      <line x1="4" y1="8" x2="11" y2="8" stroke="#808080" stroke-width="1"/>
                      <line x1="4" y1="10" x2="9" y2="10" stroke="#808080" stroke-width="1"/>
                    </svg>
                    <span style="font-size: 11px; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                      {post.frontmatter.title}
                    </span>
                    <span style="font-size: 10px; color: #808080; flex-shrink: 0;">
                      {formattedDate}
                    </span>
                  </a>
                );
              })
            }
          </nav>
        </div>
      </div>

      <!-- Status bar -->
      <div class="win95-statusbar">
        <div class="win95-statusbar-section">{sortedPosts.length} post(s)</div>
        <div class="win95-statusbar-section" style="flex: 0; min-width: 100px; text-align: center;">
          <a href="/" style="font-size: 11px; text-decoration: underline;">Back to Home</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Show/hide views based on theme */
  .dark-view {
    display: block;
  }
  .win95-view {
    display: none;
  }

  :global(.win95) .dark-view {
    display: none;
  }
  :global(.win95) .win95-view {
    display: flex;
  }

  /* Win95 specific styles */
  .win95-list-item {
    cursor: pointer;
  }

  .win95-list-item:hover {
    background: #000080;
    color: #ffffff;
  }

  .win95-list-item:hover span {
    color: #ffffff;
  }

  .win95-toolbar {
    display: flex;
    align-items: center;
    padding: 4px 8px;
    background: #c0c0c0;
    border-bottom: 1px solid #808080;
  }
</style>
