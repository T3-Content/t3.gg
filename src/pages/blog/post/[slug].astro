---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogPostHeader from "../../../components/BlogPostHeader.astro";
import { getSlugFromPath } from "../../../utils/get-slug-from-path";
import { parseISO, format } from "date-fns";

export async function getStaticPaths({ paginate, rss }) {
  const allPosts = await Astro.glob("../../../content/posts/*.md");

  const paths = allPosts.map((post) => {
    const slug = getSlugFromPath(post.file);
    return {
      params: {
        slug,
      },
      props: { post },
    };
  });

  return paths;
}

const { post } = Astro.props;
const title = post.frontmatter.title;
const description = post.frontmatter.description;
const date = parseISO(post.frontmatter.date);
const formattedDate = format(date, "MMMM d, yyyy");

const backToLink = {
  text: "blog",
  href: "/blog",
};
---

<BaseLayout {title} {description} {backToLink} win95Title={`${title.slice(0, 30)}${title.length > 30 ? '...' : ''} - Notepad`}>
  <!-- Dark theme view -->
  <div class="dark-view">
    <div class="mx-auto w-full max-w-2xl px-6 py-16">
      <article class="prose prose-invert prose-lg max-w-none">
        <BlogPostHeader post={post.frontmatter} />
        <post.Content />
      </article>
    </div>
  </div>

  <!-- Win95 theme view - Expanded window for article -->
  <div class="win95-view">
    <div class="win95-article-container">
      <div class="win95-window win95-expanded-window">
        <!-- Title bar -->
        <div class="win95-titlebar">
          <span class="win95-titlebar-text">{title.slice(0, 50)}{title.length > 50 ? '...' : ''} - Notepad</span>
          <div class="win95-titlebar-buttons">
            <button class="win95-titlebar-btn" aria-label="Minimize">_</button>
            <button class="win95-titlebar-btn" aria-label="Maximize">□</button>
            <a href="/blog" class="win95-titlebar-btn" aria-label="Close">×</a>
          </div>
        </div>

        <!-- Menu bar -->
        <div class="win95-menubar">
          <span class="win95-menu-item"><u>F</u>ile</span>
          <span class="win95-menu-item"><u>E</u>dit</span>
          <span class="win95-menu-item"><u>S</u>earch</span>
          <span class="win95-menu-item"><u>H</u>elp</span>
        </div>

        <!-- Window content - scrollable article area -->
        <div class="win95-content win95-article-content">
          <div class="win95-inset win95-article-inner">
            <!-- Article header -->
            <header class="win95-article-header">
              <h1>{title}</h1>
              <time datetime={date.toString()}>{formattedDate}</time>
            </header>

            <!-- Article body -->
            <article class="prose win95-prose">
              <post.Content />
            </article>
          </div>
        </div>

        <!-- Status bar -->
        <div class="win95-statusbar">
          <div class="win95-statusbar-section">
            <a href="/blog" style="font-size: 11px; text-decoration: underline;">← Back to Blog</a>
          </div>
          <div class="win95-statusbar-section" style="flex: 0; min-width: 120px; text-align: center;">
            {formattedDate}
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Show/hide views based on theme */
  .dark-view {
    display: block;
  }
  .win95-view {
    display: none;
  }

  :global(.win95) .dark-view {
    display: none;
  }
  :global(.win95) .win95-view {
    display: block;
  }

  /* Win95 article container */
  .win95-article-container {
    min-height: 100vh;
    padding: 16px;
    padding-bottom: 44px; /* Space for taskbar */
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  /* Expanded window for articles */
  .win95-expanded-window {
    width: 100%;
    max-width: 800px;
    margin-top: 16px;
  }

  /* Article content area */
  .win95-article-content {
    padding: 4px !important;
  }

  .win95-article-inner {
    padding: 16px;
    min-height: 400px;
    max-height: calc(100vh - 200px);
    overflow-y: auto;
  }

  /* Article header styling */
  .win95-article-header {
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 2px solid;
    border-image: linear-gradient(to right, #808080 50%, #ffffff 50%) 1;
  }

  .win95-article-header h1 {
    font-family: "Tahoma", "Segoe UI", sans-serif;
    font-size: 18px;
    font-weight: bold;
    color: #000000;
    margin: 0 0 8px 0;
    line-height: 1.3;
  }

  .win95-article-header time {
    font-family: "Tahoma", "Segoe UI", sans-serif;
    font-size: 12px;
    color: #808080;
  }

  /* Win95 prose styling for better readability */
  .win95-prose {
    font-family: "Tahoma", "Segoe UI", "Arial", sans-serif;
    font-size: 14px;
    line-height: 1.7;
    color: #000000;
  }

  .win95-prose :global(h1),
  .win95-prose :global(h2),
  .win95-prose :global(h3),
  .win95-prose :global(h4) {
    font-family: "Tahoma", "Segoe UI", sans-serif;
    font-weight: bold;
    color: #000080;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .win95-prose :global(h1) { font-size: 18px; }
  .win95-prose :global(h2) { font-size: 16px; }
  .win95-prose :global(h3) { font-size: 14px; }

  .win95-prose :global(p) {
    margin-bottom: 1em;
  }

  .win95-prose :global(a) {
    color: #000080;
    text-decoration: underline;
  }

  .win95-prose :global(a:hover) {
    color: #0000aa;
  }

  .win95-prose :global(code) {
    font-family: "Courier New", Courier, monospace;
    font-size: 13px;
    background: #ffffff;
    border: 1px solid #808080;
    padding: 1px 4px;
  }

  .win95-prose :global(pre) {
    background: #ffffff;
    border: 2px solid;
    border-color: #808080 #ffffff #ffffff #808080;
    box-shadow: inset 1px 1px 0 #404040;
    padding: 12px;
    overflow-x: auto;
    margin: 1em 0;
  }

  .win95-prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: #000000;
  }

  .win95-prose :global(ul),
  .win95-prose :global(ol) {
    padding-left: 24px;
    margin-bottom: 1em;
  }

  .win95-prose :global(li) {
    margin-bottom: 0.25em;
  }

  .win95-prose :global(blockquote) {
    border-left: 3px solid #000080;
    padding-left: 12px;
    margin: 1em 0;
    font-style: italic;
    color: #404040;
  }

  .win95-prose :global(img) {
    border: 2px solid;
    border-color: #808080 #ffffff #ffffff #808080;
    box-shadow: inset 1px 1px 0 #404040;
    max-width: 100%;
    height: auto;
  }

  .win95-prose :global(hr) {
    border: none;
    height: 2px;
    background: linear-gradient(to bottom, #808080 50%, #ffffff 50%);
    margin: 1.5em 0;
  }

  .win95-prose :global(strong) {
    font-weight: bold;
  }

  .win95-prose :global(em) {
    font-style: italic;
  }

  /* Responsive adjustments */
  @media (max-width: 640px) {
    .win95-article-container {
      padding: 8px;
      padding-bottom: 44px;
    }

    .win95-expanded-window {
      margin-top: 8px;
    }

    .win95-article-inner {
      padding: 12px;
      max-height: calc(100vh - 180px);
    }

    .win95-article-header h1 {
      font-size: 16px;
    }

    .win95-prose {
      font-size: 13px;
    }
  }
</style>
