---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogPostHeader from "../../../components/BlogPostHeader.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection(
    "posts",
    ({ data }) => !data.hidden && !data.draft,
  );

  const paths: Array<{
    params: { slug: string };
    props: { post: (typeof posts)[number]; canonicalSlug: string; isAlias: boolean };
  }> = [];

  for (const post of posts) {
    const canonicalSlug = post.id;

    paths.push({
      params: { slug: canonicalSlug },
      props: { post, canonicalSlug, isAlias: false },
    });

    const aliases = post.data.slugAliases ?? [];
    for (const alias of aliases) {
      if (!alias || alias === canonicalSlug) continue;
      paths.push({
        params: { slug: alias },
        props: { post, canonicalSlug, isAlias: true },
      });
    }
  }

  return paths;
}

const { post, canonicalSlug, isAlias } = Astro.props;
const { Content } = await render(post);

const title = post.data.title;

const fallbackDescription = post.body
  .replace(/```[\s\S]*?```/g, " ")
  .replace(/<[^>]+>/g, " ")
  .replace(/[#*_>`~\-!\[\]\(\)]/g, " ")
  .replace(/\s+/g, " ")
  .trim()
  .slice(0, 160);

const description =
  post.data.description ??
  fallbackDescription ??
  "Thought dumps and nerdy stuff";

const ogImage = post.data.cover ?? post.data.imageURL;
const canonicalPath = `/blog/post/${canonicalSlug}`;

const backToLink = {
  text: "blog",
  href: "/blog",
};
---

{
  isAlias ? (
    <BaseLayout
      {title}
      {description}
      canonicalUrl={post.data.canonicalUrl}
      ogImage={ogImage}
      ogImageAlt={post.data.coverAlt}
      ogType="article"
      publishedTime={post.data.date}
      updatedTime={post.data.updated}
      {backToLink}
    >
      <div class="mx-auto w-full max-w-2xl px-6 py-16">
        <p class="text-sm text-muted">
          Redirecting to the canonical URL.{" "}
          <a class="text-text underline" href={canonicalPath}>Continue</a>
        </p>
        <meta http-equiv="refresh" content={`0;url=${canonicalPath}`} />
      </div>
    </BaseLayout>
  ) : (
    <BaseLayout
      {title}
      {description}
      canonicalUrl={post.data.canonicalUrl}
      ogImage={ogImage}
      ogImageAlt={post.data.coverAlt}
      ogType="article"
      publishedTime={post.data.date}
      updatedTime={post.data.updated}
      {backToLink}
    >
      <div class="mx-auto w-full max-w-2xl px-6 py-16">
        <article class="prose prose-invert prose-lg max-w-none">
          <BlogPostHeader post={post} />
          <Content />
        </article>
      </div>
    </BaseLayout>
  )
}
