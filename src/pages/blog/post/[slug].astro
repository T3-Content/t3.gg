---
import type { BlogPost } from "../../../types/blog";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogPostHeader from "../../../components/BlogPostHeader.astro";
import { getSlugFromPath } from "../../../utils/get-slug-from-path";

export function getStaticPaths() {
  return Object.values(
    import.meta.glob<BlogPost>("../../../content/posts/*.md", { eager: true }),
  ).map((post) => {
    const slug = getSlugFromPath(post.file);

    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props as { post: BlogPost };
const title = post.frontmatter.title;
const description = post.frontmatter.description;

const backToLink = {
  text: "blog",
  href: "/blog",
};
---

<BaseLayout {title} {description} {backToLink}>
  <div class="mx-auto w-full max-w-2xl px-6 py-16">
    <article class="prose prose-invert prose-lg max-w-none">
      <BlogPostHeader post={post.frontmatter} />
      <post.Content />
    </article>
  </div>
</BaseLayout>
