---
import "../style/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
const siteTitle = "theo";
const description =
  "theo (aka t3, t3dotgg) is a youtuber/ceo/dev. built t3 chat, ping.gg, t3 stack and more.";

const links = [
  {
    href: "https://t3.chat",
    label: "t3.chat",
    external: true,
  },
  {
    href: "https://youtube.com/@t3dotgg",
    label: "youtube",
    external: true,
  },
  {
    href: "https://create.t3.gg",
    label: "create-t3-app",
    external: true,
  },
  {
    href: "/blog",
    label: "blog",
    external: false,
  },
  {
    href: "/sponsors",
    label: "sponsors",
    external: false,
  },
];
---

<BaseLayout title={siteTitle} description={description} win95Title="theo.exe">
  <!-- Dark theme view -->
  <div class="dark-view relative flex min-h-screen flex-col items-center justify-center px-6">
    <!-- Subtle ambient glow -->
    <div
      class="pointer-events-none absolute top-1/2 left-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-[0.03]"
      style="background: radial-gradient(circle, #22d3ee 0%, transparent 70%);"
    >
    </div>

    <div class="relative z-10 w-full max-w-xs">
      <!-- Header -->
      <header
        class="mb-16 opacity-0 animate-fade-in-up"
        style="animation-delay: 0s;"
      >
        <h1 class="text-xl tracking-tight text-text">theo</h1>
        <p class="mt-1 text-sm text-muted">builds things</p>
      </header>

      <!-- Links -->
      <nav class="flex flex-col gap-0">
        {
          links.map((link, i) => (
            <a
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
              class="group relative flex items-center justify-between py-3 opacity-0 animate-fade-in-up"
              style={`animation-delay: ${(i + 1) * 0.05}s;`}
            >
              <span class="text-subtle transition-colors duration-200 group-hover:text-text">
                {link.label}
              </span>
              <span class="text-muted opacity-0 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0.5">
                {link.external ? (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-3.5 w-3.5"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
                    <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
                  </svg>
                ) : (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-3.5 w-3.5"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                )}
              </span>
              <!-- Hover line -->
              <span class="absolute bottom-2 left-0 h-px w-0 bg-accent/40 transition-all duration-300 ease-out group-hover:w-full" />
            </a>
          ))
        }
      </nav>
    </div>
  </div>

  <!-- Win95 theme view - Classic window with title bar -->
  <div class="win95-view relative flex min-h-screen flex-col items-center justify-center p-8 pb-12">
    <div class="win95-window w-full max-w-md">
      <!-- Title bar -->
      <div class="win95-titlebar">
        <span class="win95-titlebar-text">theo.exe</span>
        <div class="win95-titlebar-buttons">
          <button class="win95-titlebar-btn" aria-label="Minimize">_</button>
          <button class="win95-titlebar-btn" aria-label="Maximize">□</button>
          <button class="win95-titlebar-btn" aria-label="Close">×</button>
        </div>
      </div>

      <!-- Menu bar -->
      <div class="win95-menubar">
        <span class="win95-menu-item"><u>F</u>ile</span>
        <span class="win95-menu-item"><u>E</u>dit</span>
        <span class="win95-menu-item"><u>V</u>iew</span>
        <span class="win95-menu-item"><u>H</u>elp</span>
      </div>

      <!-- Window content -->
      <div class="win95-content">
        <!-- Header section -->
        <div class="mb-4 pb-3" style="border-bottom: 1px solid #808080;">
          <h1 class="text-base font-bold" style="font-size: 16px; margin-bottom: 2px;">theo</h1>
          <p style="font-size: 11px; color: #808080;">builds things</p>
        </div>

        <!-- Links as Win95 style list -->
        <div class="win95-inset p-2 mb-4" style="min-height: 120px;">
          <nav class="flex flex-col">
            {
              links.map((link) => (
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                  class="win95-list-item flex items-center gap-2 px-1 py-0.5"
                >
                  {link.external ? (
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink: 0;">
                      <rect x="1" y="1" width="14" height="14" fill="#c0c0c0" stroke="#000080" stroke-width="1"/>
                      <rect x="1" y="1" width="14" height="3" fill="#000080"/>
                      <text x="8" y="10" font-size="6" fill="#000080" text-anchor="middle" font-family="sans-serif">WWW</text>
                    </svg>
                  ) : (
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink: 0;">
                      <path d="M2 2h5l2 2h5v10H2V2z" fill="#ffff00" stroke="#808000" stroke-width="0.5"/>
                      <rect x="3" y="5" width="7" height="1" fill="#808000"/>
                    </svg>
                  )}
                  <span style="font-size: 11px;">{link.label}</span>
                </a>
              ))
            }
          </nav>
        </div>

    

      <!-- Status bar -->
      <div class="win95-statusbar">
        <div class="win95-statusbar-section">Ready</div>
        <div class="win95-statusbar-section" style="flex: 0; min-width: 80px; text-align: center;">5 objects</div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Show/hide views based on theme */
  .dark-view {
    display: flex;
  }
  .win95-view {
    display: none;
  }

  :global(.win95) .dark-view {
    display: none;
  }
  :global(.win95) .win95-view {
    display: flex;
  }

  /* Win95 specific page styles */
  .win95-list-item {
    cursor: pointer;
  }

  .win95-list-item:hover {
    background: #000080;
    color: #ffffff;
  }
</style>
