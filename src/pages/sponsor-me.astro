---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import InfiniteRedLogo from "../assets/sponsors/infinite-red.svg.astro";
import SevallaLogo from "../assets/sponsors/sevalla.svg.astro";

const siteTitle = "sponsor theo";
const description = "want to sponsor theo? here's everything you need to know";

const backToLink = {
  text: "sponsors",
  href: "/sponsors",
};
---

<BaseLayout title={siteTitle} description={description} {backToLink}>
  <div class="mx-auto w-full max-w-2xl px-6 py-16">
    <article class="prose prose-invert prose-lg max-w-none">
      <header class="not-prose mb-12">
        <h1 class="text-text text-2xl font-medium tracking-tight">
          sponsor theo
        </h1>
        <p class="text-muted mt-2 text-sm">
          reach experienced developers who ship
        </p>
      </header>

      <blockquote class="not-prose border-accent/40 my-12 border-l-2 pl-6">
        <p class="text-subtle">
          Someday I'll have to tell you how transformational these ads have been
          for us. Our biggest worry is how we will service all the new clients
          going into 2025.
        </p>
        <p class="text-subtle mt-4">
          We did other ads in 2024, but
          <span class="text-text"
            >the Theo ads were by far the most effective for us</span
          >. It's clear to us that you in particular get it.
        </p>
        <div class="mt-6 flex items-center gap-3">
          <div class="text-text size-10 [&_svg]:size-full">
            <InfiniteRedLogo />
          </div>
          <div>
            <p class="text-text text-sm font-medium">Jamon</p>
            <a
              href="https://infinitered.com"
              target="_blank"
              class="text-muted hover:text-accent text-xs transition-colors"
            >
              Infinite Red
            </a>
          </div>
        </div>
      </blockquote>

      <section>
        <h2>why sponsor?</h2>
        <p>
          good developers watch my videos to learn about new technologies. my
          audience is so excited to learn about new tech that they
          <em>often like the ads more than the videos themselves</em>.
        </p>
      </section>

      <section class="not-prose my-12">
        <Image
          alt="sponsor comments"
          src={"https://ezkf3xv6eh.ufs.sh/f/3odeDX4eRzTNQlTj6vGY8AzxSWdivlGJ0fNusyEU7bKQDZBH"}
          class="cursor-pointer rounded-lg border border-white/10 transition-opacity hover:opacity-80"
          onclick={`window.open('https://ezkf3xv6eh.ufs.sh/f/3odeDX4eRzTNQlTj6vGY8AzxSWdivlGJ0fNusyEU7bKQDZBH', '_blank')`}
          width={800}
          height={400}
          loading="lazy"
        />
      </section>

      <section>
        <h2>the numbers</h2>
        <p>
          i'm in the <a
            href="https://socialblade.com/youtube/c/theobrowne1017"
            target="_blank">top 2000 youtubers in the US</a
          >. we get <strong>over 3 million views per month</strong>, often
          breaking <strong>400,000 watch hours</strong> (~2 super bowl commercials).
        </p>
        <p>
          my channel has significantly more reach than branded content
          reasonably should. big brands on youtube (like <a
            href="https://socialblade.com/youtube/c/vercelhq"
            target="_blank">vercel</a
          >) have <strong>less than 5% of my reach</strong>.
        </p>
      </section>

      <section>
        <h2>demographics</h2>
        <p>
          this isn't a bunch of beginners learning to code - my audience
          actually ships. <strong>76% of them are over 25</strong>. the most
          recent state of react survey showed that
          <em>over half of react devs watch my videos.</em>
        </p>
      </section>

      <section>
        <p>
          i've helped <a href="/sponsors"
            >over 40 brands grow their businesses</a
          >
          - will yours be next?
        </p>
      </section>

      <section
        class="not-prose bg-surface/50 my-12 rounded-lg border border-white/10 p-6 text-center"
      >
        <p class="text-subtle">
          email us at
          <span class="text-text font-medium">youtube @ (this domain)</span>
          for pricing and availability
        </p>
      </section>

      <blockquote class="not-prose border-accent/40 my-12 border-l-2 pl-6">
        <p class="text-subtle">
          I always know when you guys publish something because we have a slack
          channel with new signups and
          <span class="text-text">it's getting flooded.</span>
        </p>
        <div class="mt-6 flex items-center gap-3">
          <div class="text-text size-10 [&_svg]:size-full">
            <SevallaLogo />
          </div>
          <div>
            <p class="text-text text-sm font-medium">Paul</p>
            <a
              href="https://sevalla.com"
              target="_blank"
              class="text-muted hover:text-accent text-xs transition-colors"
            >
              Sevalla
            </a>
          </div>
        </div>
      </blockquote>
    </article>
  </div>
</BaseLayout>
