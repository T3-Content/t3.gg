---
import type { ImageMetadata } from "astro";

const sponsorImages = import.meta.glob<{
  default: ImageMetadata | astroHTML.JSX.Element;
}>("../assets/sponsors/*.{svg.astro,webp}");

interface Props {
  image: string;
  name: string;
  class?: string;
}

const { image, name, class: className } = Astro.props;

const imageImporter = sponsorImages[`../assets/sponsors/${image}`];

const isRasterImage = image.endsWith(".webp");

let BrandImage: ImageMetadata | astroHTML.JSX.Element | null = null;

if (imageImporter) {
  const imageModule = await imageImporter();
  BrandImage = imageModule.default;
}
---

<div
  role="img"
  aria-label={name}
  class:list={[
    "text-text flex shrink-0 items-center justify-center [&_img]:size-full [&_svg]:size-full",
    className ?? "size-12",
  ]}
>
  {
    BrandImage ? (
      isRasterImage ? (
        <img
          src={(BrandImage as ImageMetadata).src}
          alt=""
          class="size-full object-contain"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <BrandImage />
      )
    ) : (
      <span class="text-muted text-[10px] font-medium tracking-wider uppercase">
        {name}
      </span>
    )
  }
</div>
