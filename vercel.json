{
  "rewrites": [
    {
      "source": "/js/script.js",
      "destination": "https://plausible.io/js/plausible.js"
    },
    {
      "source": "/api/event",
      "destination": "https://plausible.io/api/event"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/blog/posts/:slug*",
      "destination": "/blog/post/:slug*"
    },

    {
      "source": "/discord",
      "destination": "https://discord.gg/xHdCpcPHRE"
    },

    {
      "source": "/youtube",
      "destination": "https://youtube.com/@t3dotgg"
    },

    {
      "source": "/twitter",
      "destination": "https://x.com/theo"
    },

    {
      "source": "/links",
      "destination": "/"
    }
  ]
}
